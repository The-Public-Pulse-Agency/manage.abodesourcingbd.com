generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; rhel-openssl-3.0.x for Vercel's Lambda runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection at runtime (Neon -pooler host); direct host for migrations.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Roles are now dynamic, per-company rows with a granular permission map (see model Role).
// User.role holds a role KEY (e.g. "ADMIN" or a custom "QC_LEAD"). SUPERADMIN is the special
// platform-operator key (no company) and is never stored as a tenant Role row.
model Role {
  id          String   @id @default(cuid())
  companyId   String? // null only for any future global roles; tenant roles set this
  key         String // stable identifier referenced by User.role
  name        String // display label
  isSystem    Boolean  @default(false) // seeded defaults — cannot be deleted/renamed-key
  permissions Json // { "<module>": ["view","create","edit","delete","approve"], ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, key])
  @@index([companyId])
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

// A tenant. Every operational row carries a companyId; queries are scoped to the
// signed-in user's company. The platform SUPERADMIN has no company (companyId null).
model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    CompanyStatus @default(ACTIVE)
  packageId String?
  signupIp  String? // source IP at self-serve signup (abuse rate-limiting)
  // Company profile + banking details printed on generated invoices (optional).
  address         String?
  bankName        String?
  bankAccountName String?
  bankAccountNo   String?
  bankSwift       String?
  bankBranch      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([signupIp, createdAt])
}

// SuperAdmin-defined subscription package (price + billing period only, per decision).
model Package {
  id         String   @id @default(cuid())
  name       String
  priceBdt   Int      @default(0)
  periodDays Int      @default(30)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          String         @default("ADMIN") // role KEY → Role.key (per company)
  active        Boolean        @default(true)
  companyId     String?        // tenant; null only for the platform SUPERADMIN
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
}

enum NotificationType {
  MILESTONE_OVERDUE
  EX_FACTORY_SOON
  DOC_MISSING
  PAYMENT_OVERDUE
  SAMPLE_PENDING
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
}

enum CostCategory {
  FABRIC
  CM
  TRIMS
  TEST
  FREIGHT
  COMMISSION
  OTHER
}

enum EnquiryStatus {
  NEW
  QUOTING
  QUOTED
  WON
  LOST
  DROPPED
}

enum MaterialKind {
  FABRIC
  TRIM
  ACCESSORY
}

enum MaterialStatus {
  BOOKED
  PARTIAL
  IN_HOUSE
}

// Fabric/trims/accessory bookings with in-house tracking — late materials are the
// #1 cause of T&A slippage. Receiving stamps the matching milestone actual date.
model MaterialBooking {
  id           String         @id @default(cuid())
  companyId String?
  poId         String
  po           PurchaseOrder  @relation(fields: [poId], references: [id], onDelete: Cascade)
  kind         MaterialKind
  description  String
  supplier     String?
  bookedQty    Decimal?       @db.Decimal(12, 2)
  unit         String?
  bookingRef   String?
  etaDate      DateTime?
  receivedQty  Decimal?       @db.Decimal(12, 2)
  receivedDate DateTime?
  status       MaterialStatus @default(BOOKED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([poId])
}

// Pre-order pipeline: buyer enquiry → quote → win/lose → convert to a draft PO.
// Buyer/brand/factory are stored as ids (no relation) to keep this module isolated.
model Enquiry {
  id               String        @id @default(cuid())
  companyId String?
  buyerId          String
  brandId          String
  factoryId        String?
  styleRef         String
  targetQty        Int?
  targetPriceUsd   Decimal?      @db.Decimal(12, 4)
  quotedPriceUsd   Decimal?      @db.Decimal(12, 4)
  priceQuotedDate  DateTime?
  fabricComposition String?
  requiredShipDate DateTime?
  status           EnquiryStatus @default(NEW)
  lostReason       String?
  notes            String?
  convertedPoId    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
}

// Standalone sample-development tracker (separate from orders). Buyer/factory stored as
// ids (no relation) to keep the module isolated; sample stages are free-text statuses.
model DevelopmentItem {
  id              String    @id @default(cuid())
  companyId       String?
  buyerId         String?
  factoryId       String?
  styleRef        String
  colour          String?
  labDip          String?
  knitting        String?
  firstSample     String?
  secondSample    String?
  finalSampleDate DateTime?
  confirmedPrice  String?
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
}

// Buyer-commission ledger: pairs a factory invoice with the buying house's own (buyer)
// invoice + commission %. Standalone (buyer/factory as ids, no relations).
model CommissionEntry {
  id                  String    @id @default(cuid())
  companyId           String?
  buyerId             String?
  factoryId           String?
  factoryInvoiceNo    String?
  factoryInvoiceValue Decimal?  @db.Decimal(14, 2)
  commissionPct       Decimal?  @db.Decimal(6, 2)
  ownInvoiceNo        String?
  issueDate           DateTime?
  dueDate             DateTime?
  paymentStatus       String?
  remarks             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([companyId])
}

// Per-PO cost build-up behind the sell FOB (reference + margin analysis).
model CostItem {
  id            String        @id @default(cuid())
  companyId String?
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  category      CostCategory
  label         String
  amountPerUnit Decimal       @db.Decimal(12, 4)
  note          String?
  createdAt     DateTime      @default(now())

  @@index([poId])
}

enum SubPaymentStatus {
  PENDING
  PAID
  FAILED
  BLOCKED
}

// Platform licensing/subscription — single org-level row (id = "singleton").
// Amount + period are admin-editable (dynamic), not hardcoded.
model Subscription {
  id               String                @id
  status           SubscriptionStatus    @default(TRIAL)
  amountBdt        Int                   @default(3333) // monthly fee in BDT (whole taka)
  periodDays       Int                   @default(30)
  minMarginPct     Int                   @default(0) // org margin floor — confirm/costing-approval gate
  planName         String                @default("ABD OMS — Managed SaaS")
  planNotes        String                @default("Full SLA, all modifications & upgrades included.")
  currentPeriodEnd DateTime
  lastPaymentAt    DateTime?
  payments         SubscriptionPayment[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model SubscriptionPayment {
  id             String           @id @default(cuid())
  orderId        String           @unique
  subscriptionId String
  subscription   Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amountBdt      Int
  status         SubPaymentStatus @default(PENDING)
  epsRef         String?
  createdAt      DateTime         @default(now())
  paidAt         DateTime?

  @@index([subscriptionId])
}

model Notification {
  id        String           @id @default(cuid())
  companyId String?
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  message   String
  link      String?
  // Stable per (rule, entity, recipient) — create-once idempotency for the daily cron.
  dedupKey  String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@unique([userId, dedupKey])
  @@index([userId, read])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId String?
  userId     String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

enum FactoryType {
  KNIT
  WOVEN
  SWEATER
  OTHER
}

model Buyer {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  code      String
  active    Boolean  @default(true)
  brands    Brand[]
  orders    PurchaseOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
}

model Brand {
  id        String   @id @default(cuid())
  companyId String?
  buyerId   String
  buyer     Buyer    @relation(fields: [buyerId], references: [id])
  name      String
  code      String
  active    Boolean  @default(true)
  styles    Style[]
  orders    PurchaseOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buyerId, code])
}

model Factory {
  id           String      @id @default(cuid())
  companyId String?
  name         String
  code         String
  type         FactoryType @default(KNIT)
  address      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  active       Boolean     @default(true)
  orders       PurchaseOrder[]
  lots         Lot[]
  certificates FactoryCertificate[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([companyId, code])
}

// Compliance certificates held by a factory (GOTS, OEKO-TEX, BSCI, GRS, …).
model FactoryCertificate {
  id         String    @id @default(cuid())
  companyId String?
  factoryId  String
  factory    Factory   @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  name       String
  number     String?
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  @@index([factoryId])
}

model SizeScale {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  active    Boolean  @default(true)
  sizes     Size[]
  styles    Style[]
  orderLines OrderLine[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model Size {
  id          String    @id @default(cuid())
  companyId String?
  sizeScaleId String
  sizeScale   SizeScale @relation(fields: [sizeScaleId], references: [id], onDelete: Cascade)
  label       String
  position    Int

  @@unique([sizeScaleId, label])
}

model Colour {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  code      String?
  active    Boolean  @default(true)
  orderLines OrderLine[]
  sampleRequests SampleRequest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
}

model Style {
  id                 String     @id @default(cuid())
  companyId String?
  brandId            String
  brand              Brand      @relation(fields: [brandId], references: [id])
  styleCode          String
  name               String
  description        String?
  composition        String?
  category           String?
  defaultSizeScaleId String?
  defaultSizeScale   SizeScale? @relation(fields: [defaultSizeScaleId], references: [id])
  active             Boolean    @default(true)
  orderLines         OrderLine[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([brandId, styleCode])
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  PARTLY_SHIPPED
  SHIPPED
  CLOSED
  CANCELLED
  ON_HOLD
}

model Lot {
  id        String          @id @default(cuid())
  companyId String?
  name      String
  factoryId String?
  factory   Factory?        @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  orders    PurchaseOrder[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PurchaseOrder {
  id            String       @id @default(cuid())
  companyId String?
  poNumber      String
  buyerId       String
  buyer         Buyer        @relation(fields: [buyerId], references: [id])
  brandId       String
  brand         Brand        @relation(fields: [brandId], references: [id])
  channel       String       @default("DIRECT")
  factoryId     String
  factory       Factory      @relation(fields: [factoryId], references: [id])
  lotId         String?
  lot           Lot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  orderDate     DateTime?
  crd           DateTime?
  exFactoryDate DateTime?
  currency      String       @default("USD")
  status        OrderStatus  @default(DRAFT)
  notes         String?
  costingApprovedById String?
  costingApprovedAt   DateTime?
  lines          OrderLine[]
  milestones     TaMilestone[]
  sampleRequests SampleRequest[]
  production     ProductionRecord[]
  inspections    Inspection[]
  invoices       Invoice[]
  costItems      CostItem[]
  materials      MaterialBooking[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([buyerId, factoryId, channel, poNumber])
  @@index([status])
  @@index([exFactoryDate])
  @@index([factoryId])
}

model OrderLine {
  id          String          @id @default(cuid())
  companyId String?
  poId        String
  po          PurchaseOrder   @relation(fields: [poId], references: [id], onDelete: Cascade)
  styleId     String
  style       Style           @relation(fields: [styleId], references: [id])
  colourId    String?
  colour      Colour?         @relation(fields: [colourId], references: [id])
  colourKey   String          @default("")
  sizeScaleId String?
  sizeScale   SizeScale?      @relation(fields: [sizeScaleId], references: [id])
  sizes       OrderLineSize[]
  shipmentLines ShipmentLine[]
  production  ProductionRecord?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([poId, styleId, colourKey])
}

model OrderLineSize {
  id          String    @id @default(cuid())
  companyId String?
  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  label       String
  position    Int       @default(0)
  qty         Int       @default(0)
  netFob      Decimal   @default(0) @db.Decimal(12, 4)
  sellFob     Decimal   @default(0) @db.Decimal(12, 4)

  @@unique([orderLineId, label])
}

enum TaStage {
  PRE_PRODUCTION
  SAMPLING
  PRODUCTION_QC
  SHIPPING
}

model TaMilestoneTemplate {
  id         String   @id @default(cuid())
  companyId  String?
  key        String
  name       String
  stage      TaStage
  offsetDays Int?
  position   Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, key])
}

model TaMilestone {
  id          String        @id @default(cuid())
  companyId String?
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  key         String
  name        String
  stage       TaStage
  position    Int
  offsetDays  Int?
  plannedDate DateTime?
  actualDate  DateTime?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([poId, key])
  @@index([plannedDate])
}

enum SampleType {
  LAB_DIP
  FIT
  PP
  SIZE_SET
}

enum SampleStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum InspectionType {
  INLINE
  FINAL
}

enum InspectionResult {
  PASS
  FAIL
}

model SampleRequest {
  id           String        @id @default(cuid())
  companyId String?
  poId         String
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  colourId     String?
  colour       Colour?       @relation(fields: [colourId], references: [id])
  type         SampleType
  status       SampleStatus  @default(PENDING)
  sentDate     DateTime?
  approvedDate DateTime?
  remarks      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([poId])
}

model ProductionRecord {
  id          String        @id @default(cuid())
  companyId   String?
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  // Production is tracked per order line (style/colour); one record per line.
  orderLineId String?       @unique
  orderLine   OrderLine?    @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  cutQty      Int           @default(0)
  sewQty      Int           @default(0)
  finishQty   Int           @default(0)
  // Per-line status remarks shown above the cut/sew/finish bars.
  shadeApproval    String?
  fabricWashTest   String?
  garmentsWashTest String?
  topSampleStatus  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([poId])
}

model Inspection {
  id        String           @id @default(cuid())
  companyId String?
  poId      String
  po        PurchaseOrder    @relation(fields: [poId], references: [id], onDelete: Cascade)
  type      InspectionType
  result    InspectionResult
  date      DateTime
  aql       String?
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([poId])
}

/// Outbound buyer-sample dispatch log (samples couriered to a buyer).
model BuyerSampleDispatch {
  id            String    @id @default(cuid())
  companyId     String?
  buyerName     String?
  sampleType    String?
  artNo         String?
  styleName     String?
  factoryName   String?
  courierName   String?
  awbNumber     String?
  sendDate      DateTime?
  numSamples    Int?
  approxArrival DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
}

/// Dhaka office sample in/out ledger. direction = "IN" | "OUT"; balance/status are derived
/// per artNo (total IN − total OUT).
model SampleMovement {
  id           String    @id @default(cuid())
  companyId    String?
  direction    String // "IN" (received) or "OUT" (sent)
  movementDate DateTime?
  sampleType   String?
  qty          Int?
  artNo        String? // auto-sync key
  buyer        String?
  poNumber     String? // IN
  factoryName  String? // IN
  colour       String? // IN
  receivedFrom String? // IN
  sentTo       String? // OUT — sent to / carried by
  courierName  String? // OUT
  awbNumber    String? // OUT
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([artNo])
}

enum ShipmentMode {
  SEA
  AIR
}

enum TelexStatus {
  PENDING
  RECEIVED
  RELEASED
}

enum DocumentType {
  BL
  COMMERCIAL_INVOICE
  PACKING_LIST
  TEST_CERT
  INSPECTION_REPORT
  SAMPLE_PHOTO
  OTHER
}

model Port {
  id        String     @id @default(cuid())
  companyId String?
  name      String
  country   String?
  active    Boolean    @default(true)
  shipments Shipment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([companyId, name])
}

model Forwarder {
  id        String     @id @default(cuid())
  companyId String?
  name      String
  contact   String?
  active    Boolean    @default(true)
  shipments Shipment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([companyId, name])
}

model Shipment {
  id            String         @id @default(cuid())
  companyId String?
  reference     String
  mode          ShipmentMode   @default(SEA)
  containerNo   String?
  cartons       Int?
  exFactoryDate DateTime?
  blNumber      String?
  blDate        DateTime?
  etaDestination DateTime?     // estimated arrival at destination port
  remarks       String?        // free-text remarks
  telexStatus   TelexStatus    @default(PENDING)
  tcStatus      String?        // transaction-certificate status (free text: Working / NO TC / Send <date>)
  forwarderId   String?
  forwarder     Forwarder?     @relation(fields: [forwarderId], references: [id], onDelete: SetNull)
  portId        String?
  port          Port?          @relation(fields: [portId], references: [id], onDelete: SetNull)
  lines         ShipmentLine[]
  invoices      Invoice[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([telexStatus])

  @@unique([companyId, reference])
  @@unique([companyId, blNumber])
}

enum InvoiceType {
  BUYER
  FACTORY
}

enum InvoiceStatus {
  ISSUED
  PARTIALLY_PAID
  PAID
}

enum PaymentMethod {
  LC
  TT
  OTHER
}

model Invoice {
  id         String         @id @default(cuid())
  companyId String?
  type       InvoiceType
  number     String
  poId       String?
  po         PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: SetNull)
  shipmentId String?
  shipment   Shipment?      @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  amount     Decimal        @db.Decimal(14, 2)
  currency   String         @default("USD")
  issueDate  DateTime
  dueDate    DateTime?      // payment due date (drives true past-due aging)
  status     InvoiceStatus  @default(ISSUED)
  payments   Payment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([companyId, type, number])
  @@index([status])
  @@index([issueDate])
  @@index([poId])
  @@index([shipmentId])
}

model Payment {
  id        String        @id @default(cuid())
  companyId String?
  invoiceId String
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(14, 2)
  date      DateTime
  method    PaymentMethod @default(TT)
  reference String?
  createdAt DateTime      @default(now())

  @@index([invoiceId])
}

model ShipmentLine {
  id          String             @id @default(cuid())
  companyId String?
  shipmentId  String
  shipment    Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderLineId String
  orderLine   OrderLine          @relation(fields: [orderLineId], references: [id])
  sizes       ShipmentLineSize[]
  note        String? // auto-set on over-shipment, e.g. "Over-ship: XS-2XL +300 pcs"
  createdAt   DateTime           @default(now())

  @@unique([shipmentId, orderLineId])
  @@index([orderLineId])
}

model ShipmentLineSize {
  id             String       @id @default(cuid())
  companyId String?
  shipmentLineId String
  shipmentLine   ShipmentLine @relation(fields: [shipmentLineId], references: [id], onDelete: Cascade)
  label          String
  qty            Int

  @@unique([shipmentLineId, label])
}

model Document {
  id           String       @id @default(cuid())
  companyId String?
  entityType   String
  entityId     String
  type         DocumentType
  fileName     String
  fileUrl      String?
  storageKey   String? // private Vercel Blob pathname (uploaded files); null for external links
  uploadedById String?
  createdAt    DateTime     @default(now())

  @@index([entityType, entityId])
}
