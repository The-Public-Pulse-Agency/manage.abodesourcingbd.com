# Copy to .env and fill in.
# DATABASE_URL = connection used by the app at runtime.
#   - On Vercel use the Neon POOLED host (…-pooler.…) to survive serverless concurrency.
#   - Locally the direct host is fine.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# DIRECT_URL = non-pooled host, used ONLY by `prisma migrate`. On Neon this is the
# host WITHOUT "-pooler". Locally it can equal DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DB?sslmode=require"

# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# Daily alert cron (GET/POST /api/cron/alerts with header: Authorization: Bearer $CRON_SECRET).
# If unset, the endpoint fails closed (503). Generate with: openssl rand -base64 32
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Optional email channel for alert digests. Without RESEND_API_KEY, digests log only.
# RESEND_API_KEY=""
# ALERT_EMAIL_FROM="alerts@abodesourcingbd.com"

# Absolute app URL (used for EPS payment redirect callbacks).
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# --- Subscription billing via EPS (eps.com.bd) ---
# SAFETY: keep "1" everywhere except production — when 1, EPS hard-refuses to charge.
STAGING_PAYMENT_BLOCK="1"
# EPS hosted-checkout credentials (provider-issued). Leave blank to disable payments.
EPS_MERCHANT_ID=""
EPS_STORE_ID=""
EPS_USERNAME=""
EPS_PASSWORD=""
EPS_HASH_KEY=""
# Optional: defaults to https://pgapi.eps.com.bd. Set EPS_SANDBOX="1" for sandbox.
# EPS_BASE_URL=""
# EPS_SANDBOX=""
