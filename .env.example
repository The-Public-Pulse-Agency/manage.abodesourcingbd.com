# Copy to .env and fill in.
# Dev DB options:
#   - Neon (managed):  postgresql://USER:PASSWORD@HOST/DB?sslmode=require
#   - Docker local:    postgresql://abd:abd@localhost:5432/abd_oms?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# Daily alert cron (GET/POST /api/cron/alerts with header: Authorization: Bearer $CRON_SECRET).
# If unset, the endpoint fails closed (503). Generate with: openssl rand -base64 32
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Optional email channel for alert digests. Without RESEND_API_KEY, digests log only.
# RESEND_API_KEY=""
# ALERT_EMAIL_FROM="alerts@abodesourcingbd.com"
